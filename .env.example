PORT=5000
HOST=127.0.0.1
CLIENT_ORIGIN=http://localhost:5173
SESSION_SECRET=change-this-long-random-secret

# Admin login
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Required for storing mail templates. Also used for sessions when provided.
MONGO_URI=

# SMTP settings. For Gmail, use an App Password, not your normal account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM="Bulk Mail Sender <your-email@gmail.com>"
